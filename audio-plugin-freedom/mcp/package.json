{
  "name": "audio-plugin-freedom-mcp",
  "version": "0.1.0",
  "description": "MCP server for the audio-plugin-freedom plugin — JUCE-domain analysis tools (RT safety, APVTS, pluginval, oversampling, project phase).",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "audio-plugin-freedom-mcp": "dist/index.js"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "bundle": "esbuild src/index.ts --bundle --platform=node --target=node20 --format=esm --outfile=dist/index.js",
    "build": "npm run typecheck && npm run bundle",
    "watch": "tsc --watch --noEmit",
    "start": "node dist/index.js",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "esbuild": "^0.28.0",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "MIT"
}
